using Dapper;
using DL.Interface;
using Model;

namespace DL
{
    public class CustomerRepository : BaseDL<Customer>, ICustomerRepository
    {
        protected override string TableName => "customer";

        public CustomerRepository(IDbConnectionFactory dbFactory) : base(dbFactory)
        {
        }

        public async Task<IEnumerable<Customer>> GetAllAsync()
        {
            const string query = "SELECT * FROM customer";
            using var connection = _connectionFactory.CreateConnection();
            return await connection.QueryAsync<Customer>(query);
        }

        public async Task<Customer?> GetByIdAsync(Guid id)
        {
            const string query = "SELECT * FROM customer WHERE customer_id = @Id";
            using var connection = _connectionFactory.CreateConnection();
            return await connection.QueryFirstOrDefaultAsync<Customer>(query, new { Id = id });
        }

        public async Task<int> AddAsync(Customer customer)
        {
            const string query = @"
                INSERT INTO customer (customer_id, customer_code, customer_name, customer_addr, create_date, create_by, modified_date, modified_by)
                VALUES (@CustomerId, @CustomerCode, @CustomerName, @CustomerAddr, @CreateDate, @CreateBy, @ModifiedDate, @ModifiedBy)";

            using var connection = _connectionFactory.CreateConnection();
            return await connection.ExecuteAsync(query, customer);
        }

        public async Task<int> UpdateAsync(Customer customer)
        {
            const string query = @"
                UPDATE customer 
                SET customer_code = @CustomerCode, 
                    customer_name = @CustomerName, 
                    customer_addr = @CustomerAddr, 
                    modified_date = @ModifiedDate, 
                    modified_by = @ModifiedBy
                WHERE customer_id = @CustomerId";

            using var connection = _connectionFactory.CreateConnection();
            return await connection.ExecuteAsync(query, customer);
        }

        public async Task<int> DeleteAsync(Guid id)
        {
            const string query = "DELETE FROM customer WHERE customer_id = @Id";
            using var connection = _connectionFactory.CreateConnection();
            return await connection.ExecuteAsync(query, new { Id = id });
        }

        public async Task<int> DeleteMultipleAsync(IEnumerable<Guid> ids)
        {
            const string query = "DELETE FROM customer WHERE customer_id IN @Ids";
            using var connection = _connectionFactory.CreateConnection();
            return await connection.ExecuteAsync(query, new { Ids = ids });
        }
    }
}