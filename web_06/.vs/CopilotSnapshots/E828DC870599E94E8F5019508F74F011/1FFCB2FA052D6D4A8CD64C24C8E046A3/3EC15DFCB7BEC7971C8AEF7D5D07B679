using BL.Interface;
using DL.Interface;
using Model;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace BL
{
    public class EmployeeBL : IEmployeeBL
    {

        private readonly IEmployeeRepository _repository;

        public EmployeeBL(IEmployeeRepository repository)
        {
            _repository = repository;
        }

        public async Task<IEnumerable<Customer>> GetEmployeesAsync()
        {
            return await _repository.GetAllAsync();
        }

        public async Task<Customer?> GetEmployeeByIdAsync(Guid id)
        {
            return await _repository.GetByIdAsync(id);
        }

        public async Task<int> AddEmployeeAsync(Customer employee)
        {
            employee.CustomerId = Guid.NewGuid();
            return await _repository.AddAsync(employee);
        }

        public async Task<int> UpdateEmployeeAsync(Customer employee)
        {
            return await _repository.UpdateAsync(employee);
        }

        public async Task<int> DeleteEmployeeAsync(Guid id)
        {
            return await _repository.DeleteAsync(id);
        }

        public async Task<int> DeleteEmployeesAsync(IEnumerable<Guid> ids)
        {
            return await _repository.DeleteMultipleAsync(ids);
        }



    }
}