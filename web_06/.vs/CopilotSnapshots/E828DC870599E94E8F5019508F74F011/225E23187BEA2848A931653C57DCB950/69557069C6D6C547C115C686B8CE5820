using BL.Interface;
using Microsoft.AspNetCore.Mvc;
using Model;

namespace web_06.Controllers
{
    [Route("api/v1/[controller]")]
    [ApiController]
    public class SaleOrderController : ControllerBase
    {
        private readonly ISaleOrderBL _saleOrderBL;

        public SaleOrderController(ISaleOrderBL saleOrderBL)
        {
            _saleOrderBL = saleOrderBL;
        }

        [HttpGet]
        public async Task<IActionResult> GetAll()
        {
            var result = await _saleOrderBL.GetAllAsync();
            return Ok(result);
        }

        [HttpGet("{id}")]
        public async Task<IActionResult> GetById(Guid id)
        {
            var result = await _saleOrderBL.GetByIdAsync(id);
            if (result == null)
                return NotFound();
            return Ok(result);
        }

        [HttpPost]
        public async Task<IActionResult> Add([FromBody] SaleOrder saleOrder)
        {
            var result = await _saleOrderBL.AddAsync(saleOrder);
            return Ok(new { message = "Added successfully", affectedRows = result });
        }

        [HttpPut]
        public async Task<IActionResult> Update([FromBody] SaleOrder saleOrder)
        {
            var result = await _saleOrderBL.UpdateAsync(saleOrder);
            return Ok(new { message = "Updated successfully", affectedRows = result });
        }

        [HttpDelete("{id}")]
        public async Task<IActionResult> Delete(Guid id)
        {
            var result = await _saleOrderBL.DeleteAsync(id);
            if (result == 0)
                return NotFound();
            return Ok(new { message = "Deleted successfully", affectedRows = result });
        }

        [HttpPost("delete-multiple")]
        public async Task<IActionResult> DeleteMultiple([FromBody] IEnumerable<Guid> ids)
        {
            var result = await _saleOrderBL.DeleteMultipleAsync(ids);
            return Ok(new { message = "Deleted successfully", affectedRows = result });
        }
    }
}
