using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

using System.ComponentModel.DataAnnotations.Schema;

namespace Model
{
    /// <summary>
    /// Đại diện cho một khách hàng
    /// </summary>
    public class Customer : BaseModel
    {
        // Override [Column] từ BaseModel để map đúng column name trong DB
        [Column("customer_id")]
        public new Guid Id { get; set; }

        [Column("customer_code")]
        public string? CustomerCode { get; set; }

        [Column("customer_name")]
        public string? CustomerName { get; set; }

        [Column("customer_addr")]
        public string? CustomerAddr { get; set; }

        // Kế thừa từ BaseModel:
        // - Id (Column: customer_id)
        // - CreatedDate (Column: create_date)
        // - CreatedBy (Column: create_by)
        // - ModifiedDate (Column: modified_date)
        // - ModifiedBy (Column: modified_by)
    }
}
