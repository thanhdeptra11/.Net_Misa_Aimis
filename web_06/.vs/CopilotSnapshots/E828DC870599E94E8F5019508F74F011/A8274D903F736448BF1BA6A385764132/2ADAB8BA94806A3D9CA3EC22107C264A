using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Model
{
    /// <summary>
    /// Đại diện cho một đơn hàng bán
    /// </summary>
    public class SaleOrder : BaseModel
    {
        /// <summary>
        /// ID khách hàng
        /// </summary>
        public Guid CustomerId { get; set; }

        /// <summary>
        /// Mã đơn hàng
        /// </summary>
        public string? SaleOrderNo { get; set; }

        /// <summary>
        /// Ngày đơn hàng
        /// </summary>
        public DateTime SaleOrderDate { get; set; }

        /// <summary>
        /// Tổng tiền
        /// </summary>
        public decimal TotalAmount { get; set; }

        // Kế thừa từ BaseModel:
        // - Id (Guid): ID đơn hàng
        // - CreatedDate (DateTime): Ngày tạo
        // - CreatedBy (string?): Người tạo
        // - ModifiedDate (DateTime?): Ngày sửa đổi
        // - ModifiedBy (string?): Người sửa đổi
    }
}
