using BL.Interface;
using Common.Model;
using Microsoft.AspNetCore.Mvc;

namespace web_06.Controllers
{
    public class SaleOrderDetailController : BasesController<SaleOrderDetail>
    {
        private readonly ISaleOrderDetailBL _saleOrderDetailBL;

        public SaleOrderDetailController(ISaleOrderDetailBL saleOrderDetailBL) : base(saleOrderDetailBL)
        {
            _saleOrderDetailBL = saleOrderDetailBL;
        }

        /// <summary>
        /// Lấy tất cả chi tiết đơn hàng theo ID đơn hàng
        /// GET: /api/v1/saleorderdetail/by-order/{saleOrderId}
        /// </summary>
        [HttpGet("by-order/{saleOrderId}")]
        public async Task<IActionResult> GetDetailsByOrderId(Guid saleOrderId)
        {
            var result = await _saleOrderDetailBL.GetDetailsByOrderIdAsync(saleOrderId);
            if (result == null || !result.Any())
                return NotFound(new { message = "No details found for this order" });
            
            return Ok(result);
        }
    }
}
